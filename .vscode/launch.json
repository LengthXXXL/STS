{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: backend FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "args": [
        "app.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "jinja": false,
      "justMyCode": true,
      "subProcess": true
    },
    {
      "name": "Run: frontend Vite",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Run: STS full stack",
      "configurations": [
        "Debug: backend FastAPI",
        "Run: frontend Vite"
      ],
      "stopAll": true
    }
  ]
}
